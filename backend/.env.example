# ============================================================
# .env.example — Template de configuration (commité dans Git)
# ============================================================
# Copier ce fichier en .env et remplir les vraies valeurs.

# Base de données
DB_HOST=localhost
DB_NAME=portfolio_db
DB_USER=your_db_user
DB_PASS=your_db_password

# JWT — Générer avec : php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING

# CORS — Origines autorisées (séparer par virgule si plusieurs)
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:3000

# Email admin pour les notifications de contact
ADMIN_EMAIL=your@email.com
